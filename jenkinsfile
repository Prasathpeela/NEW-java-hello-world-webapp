pipeline {
    agent any

    tools {
        maven 'mvn'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master', 
                url: 'https://github.com/Prasathpeela/NEW-java-hello-world-webapp.git'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'target/*.war'
            }
        }

        stage('Deploy') {
            steps {
                deploy adapters: [
                    tomcat9(
                        credentialsId: 'tomcat', 
                        path: '/manager/text', 
                        url: 'http://localhost:8090'
                    )
                ], 
                contextPath: "java-hello-world", 
                war: '**/*.war'
            }
        }
    }
}
