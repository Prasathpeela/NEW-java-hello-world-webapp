pipeline {
    agent any

    tools {
        maven 'mvn'
    }

    stages {

        stage('Checkout') {
            steps {
                echo 'Source code checkout'
            }
        }

        stage('Build') {
            steps {
                bat 'mvn clean package'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing completed'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'target/*.war'
            }
        }
    }
}
